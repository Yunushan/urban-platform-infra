# Docker standalone compatibility profile.
# Copy this file to .env.standalone and keep real IPs, FQDNs, and passwords private.

REGISTRY_PREFIX=
STANDALONE_BIND_IP=0.0.0.0
STANDALONE_DOMAIN=app.example.local
STANDALONE_HTTP_PORT=80
STANDALONE_HTTPS_PORT=443
STANDALONE_TLS_MODE=self-signed
STANDALONE_TLS_EXTRA_SANS=IP:192.0.2.10
STANDALONE_TLS_CERT_FILE=
STANDALONE_TLS_KEY_FILE=
STANDALONE_TLS_PFX_FILE=
STANDALONE_TLS_PFX_PASSWORD_FILE=
STANDALONE_AUTO_INSTALL_OPENSSL=true
STANDALONE_RUNTIME_DIR=.standalone
STANDALONE_UPSTREAM_URL=http://app-27:5000

STANDALONE_NGINX_IMAGE=nginxinc/nginx-unprivileged:1.30.2
STANDALONE_POSTGRES_IMAGE=postgres:18.3
STANDALONE_POSTGIS_IMAGE=postgis/postgis:18-3.6
STANDALONE_TIMESCALE_IMAGE=timescale/timescaledb:2.26.4-pg18
STANDALONE_KAFKA_EXTERNAL_HOST=localhost

POSTGRES_PASSWORD=change-me
