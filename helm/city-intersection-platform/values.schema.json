{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "projectName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 63
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "imageRegistry": {
          "type": "string"
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/kubernetesName"
          },
          "uniqueItems": true
        },
        "imagePullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        },
        "enableServiceLinks": {
          "type": "boolean"
        },
        "defaultReplicas": {
          "type": "integer",
          "minimum": 1
        },
        "replicaOverride": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "serviceAccount": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "create": {
              "type": "boolean"
            },
            "name": {
              "type": "string",
              "maxLength": 63
            },
            "automountServiceAccountToken": {
              "type": "boolean"
            }
          },
          "required": [
            "create",
            "automountServiceAccountToken"
          ]
        },
        "cluster": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "engine": {
              "type": "string",
              "enum": [
                "rke2",
                "k3s",
                "kubernetes"
              ]
            },
            "nodes": {
              "type": "integer",
              "minimum": 1
            },
            "defaultOs": {
              "type": "string",
              "minLength": 1
            },
            "vip": {
              "type": "string"
            },
            "domain": {
              "type": "string"
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runAsNonRoot": {
              "type": "boolean"
            },
            "readOnlyRootFilesystem": {
              "type": "boolean"
            },
            "allowPrivilegeEscalation": {
              "type": "boolean"
            },
            "capabilities": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "drop": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                }
              },
              "required": [
                "drop"
              ]
            }
          },
          "required": [
            "runAsNonRoot",
            "readOnlyRootFilesystem",
            "allowPrivilegeEscalation"
          ]
        },
        "podSecurityContext": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "fsGroupChangePolicy": {
              "type": "string",
              "enum": [
                "Always",
                "OnRootMismatch"
              ]
            },
            "seccompProfile": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "RuntimeDefault",
                    "Localhost",
                    "Unconfined"
                  ]
                }
              },
              "required": [
                "type"
              ]
            }
          },
          "required": [
            "enabled"
          ]
        },
        "scheduling": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "topologySpread": {
              "type": "boolean"
            },
            "antiAffinity": {
              "type": "string",
              "enum": [
                "preferred",
                "required",
                "disabled"
              ]
            }
          },
          "required": [
            "topologySpread",
            "antiAffinity"
          ]
        }
      },
      "required": [
        "projectName",
        "environment",
        "enableServiceLinks",
        "defaultReplicas",
        "serviceAccount",
        "security",
        "scheduling"
      ]
    },
    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean"
        },
        "name": {
          "$ref": "#/$defs/kubernetesName"
        },
        "podSecurity": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enforce": {
              "$ref": "#/$defs/podSecurityLevel"
            },
            "audit": {
              "$ref": "#/$defs/podSecurityLevel"
            },
            "warn": {
              "$ref": "#/$defs/podSecurityLevel"
            },
            "version": {
              "type": "string",
              "pattern": "^(latest|v[0-9]+\\.[0-9]+)$"
            }
          },
          "required": [
            "enforce",
            "audit",
            "warn",
            "version"
          ]
        }
      },
      "required": [
        "create",
        "name",
        "podSecurity"
      ]
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "secretName": {
              "type": "string"
            }
          },
          "required": [
            "enabled",
            "secretName"
          ]
        }
      }
    },
    "secretManagement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "external-secrets"
          ]
        },
        "refreshInterval": {
          "type": "string",
          "pattern": "^[0-9]+[smhd]$"
        },
        "secretStoreRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "$ref": "#/$defs/kubernetesName"
            },
            "kind": {
              "type": "string",
              "enum": [
                "SecretStore",
                "ClusterSecretStore"
              ]
            }
          },
          "required": [
            "name",
            "kind"
          ]
        },
        "externalSecrets": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/externalSecret"
          }
        }
      },
      "required": [
        "enabled",
        "provider",
        "refreshInterval",
        "secretStoreRef",
        "externalSecrets"
      ]
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "default": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "minReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "maxReplicas": {
              "type": "integer",
              "minimum": 1
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "required": [
            "minReplicas",
            "maxReplicas",
            "targetCPUUtilizationPercentage"
          ]
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "defaultDeny": {
          "$ref": "#/$defs/toggle"
        },
        "sameNamespace": {
          "$ref": "#/$defs/toggle"
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespaces": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/kubernetesName"
              },
              "uniqueItems": true
            }
          },
          "required": [
            "enabled",
            "namespaces"
          ]
        },
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "namespace": {
              "$ref": "#/$defs/kubernetesName"
            },
            "podLabels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            }
          },
          "required": [
            "enabled",
            "namespace",
            "podLabels"
          ]
        },
        "externalWeb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "cidrs": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minItems": 1,
              "uniqueItems": true
            },
            "ports": {
              "type": "array",
              "items": {
                "type": "integer",
                "minimum": 1,
                "maximum": 65535
              },
              "minItems": 1,
              "uniqueItems": true
            }
          },
          "required": [
            "enabled",
            "cidrs",
            "ports"
          ]
        }
      },
      "required": [
        "enabled",
        "defaultDeny",
        "sameNamespace",
        "ingress",
        "dns",
        "externalWeb"
      ]
    },
    "webserver": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "provider": {
          "type": "string",
          "enum": [
            "nginx",
            "apache-httpd",
            "apache-tomcat",
            "traefik"
          ]
        },
        "service": {
          "$ref": "#/$defs/service"
        },
        "providers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "displayName": {
                "type": "string"
              },
              "image": {
                "$ref": "#/$defs/image"
              },
              "imagePullPolicy": {
                "$ref": "#/$defs/imagePullPolicy"
              },
              "replicas": {
                "type": "integer",
                "minimum": 1
              },
              "ports": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/port"
                },
                "minItems": 1
              },
              "configTemplate": {
                "type": "string"
              },
              "securityContext": {
                "type": "object"
              }
            },
            "required": [
              "enabled",
              "image",
              "ports"
            ]
          }
        }
      },
      "required": [
        "provider",
        "service",
        "providers"
      ]
    },
    "workloads": {
      "type": "object",
      "propertyNames": {
        "pattern": "^app-[0-9]{2}$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/workload"
      }
    },
    "databases": {
      "type": "object"
    },
    "observability": {
      "type": "object"
    },
    "monitoring": {
      "type": "object"
    },
    "messaging": {
      "type": "object"
    },
    "zabbixAgent": {
      "type": "object"
    }
  },
  "required": [
    "global",
    "namespace",
    "webserver",
    "workloads"
  ],
  "$defs": {
    "kubernetesName": {
      "type": "string",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$",
      "minLength": 1,
      "maxLength": 63
    },
    "podSecurityLevel": {
      "type": "string",
      "enum": [
        "privileged",
        "baseline",
        "restricted"
      ]
    },
    "toggle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ]
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": [
        "Always",
        "IfNotPresent",
        "Never"
      ]
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1,
          "not": {
            "pattern": "(^latest($|-)|-latest$)"
          }
        },
        "digest": {
          "type": "string",
          "pattern": "^sha256:[A-Fa-f0-9]{64}$"
        }
      },
      "anyOf": [
        {
          "required": [
            "tag"
          ]
        },
        {
          "required": [
            "digest"
          ]
        }
      ],
      "required": [
        "repository"
      ]
    },
    "port": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "containerPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "servicePort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "range": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "namePrefix": {
              "type": "string"
            },
            "start": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "end": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          },
          "required": [
            "start",
            "end"
          ]
        }
      },
      "anyOf": [
        {
          "required": [
            "containerPort"
          ]
        },
        {
          "required": [
            "range"
          ]
        }
      ]
    },
    "externalSecret": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "targetName": {
          "$ref": "#/$defs/kubernetesName"
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "creationPolicy": {
          "type": "string",
          "enum": [
            "Owner",
            "Orphan",
            "Merge",
            "None"
          ]
        },
        "immutable": {
          "type": "boolean"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "secretKey": {
                "type": "string",
                "minLength": 1
              },
              "remoteRef": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "key": {
                    "type": "string",
                    "minLength": 1
                  },
                  "property": {
                    "type": "string",
                    "minLength": 1
                  },
                  "version": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "key"
                ]
              }
            },
            "required": [
              "secretKey",
              "remoteRef"
            ]
          },
          "minItems": 1
        }
      },
      "required": [
        "enabled",
        "targetName",
        "type",
        "creationPolicy",
        "immutable",
        "data"
      ]
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "loadBalancerSourceRanges": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "required": [
        "type"
      ]
    },
    "workload": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "kind": {
          "type": "string",
          "enum": [
            "Deployment",
            "StatefulSet"
          ]
        },
        "category": {
          "type": "string"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "imagePullPolicy": {
          "$ref": "#/$defs/imagePullPolicy"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/port"
          },
          "minItems": 1
        },
        "service": {
          "$ref": "#/$defs/service"
        },
        "env": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": [
                  "string",
                  "number",
                  "integer",
                  "boolean"
                ]
              }
            },
            "required": [
              "name"
            ]
          }
        },
        "resources": {
          "type": "object"
        },
        "autoscaling": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          }
        },
        "ingress": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "path": {
              "type": "string"
            }
          }
        },
        "probe": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "type": {
              "type": "string"
            },
            "port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            }
          }
        }
      },
      "required": [
        "enabled",
        "kind",
        "image",
        "ports"
      ]
    }
  }
}
