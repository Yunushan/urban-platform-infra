vrrp_script chk_haproxy {
  script "pidof haproxy"
  interval 2
  weight 2
}

vrrp_instance VI_1 {
  state BACKUP
  interface {{ keepalived_interface | default('eth0') }}
  virtual_router_id 51
  priority {{ keepalived_priority | default(100) }}
  advert_int 1
  authentication {
    auth_type PASS
    auth_pass {{ keepalived_auth_pass }}
  }
  virtual_ipaddress {
    {{ cluster_vip }}
  }
  track_script {
    chk_haproxy
  }
}
